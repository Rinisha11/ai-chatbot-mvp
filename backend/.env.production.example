APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=5000
SITE_CONFIG_PATH=./sites.json
ALLOWED_ORIGINS=https://your-frontend-domain.com

CHATBOT_BRAND=Example Company
CHATBOT_ASSISTANT_NAME=Support Assistant
CHATBOT_WELCOME_MESSAGE=Hi, how can I help you today?
SYSTEM_PROMPT_SUFFIX=

OPENAI_API_KEY=replace-with-your-production-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
LOG_LEVEL=INFO

CHROMA_DIR=./akinfoChroma
DATA_DIR=./data
CHAT_LOG_PATH=./chat_logs_modern.jsonl
CHROMA_SERVER_HOST=
CHROMA_SERVER_HTTP_PORT=8000
