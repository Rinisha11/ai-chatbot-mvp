# Root reference env template for the backend.
# For actual local work, copy these values into backend/.env.
# For production, use backend/.env.production.example as the template.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=5001
SITE_CONFIG_PATH=../sites.json
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5500,http://localhost:5001,http://127.0.0.1:5001

CHATBOT_BRAND=Example Company
CHATBOT_ASSISTANT_NAME=Support Assistant
CHATBOT_WELCOME_MESSAGE=Hi, how can I assist you?
SYSTEM_PROMPT_SUFFIX=

# --- CRITICAL SECRETS ---
# Standard standard standard: Do not provide default keys in templates.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
JWT_SECRET_KEY=replace-with-a-long-random-secret
LOG_LEVEL=INFO

# Local Vector Fallback - segmented MVP pattern enforced
CHROMA_DIR=./akinfoChroma
DATA_DIR=../data
CHAT_LOG_PATH=./chat_logs_modern.jsonl
CHROMA_SERVER_HOST=
CHROMA_SERVER_HTTP_PORT=8000
